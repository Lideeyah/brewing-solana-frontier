{
  "name": "brewing-sdk",
  "version": "0.2.0",
  "description": "TypeScript SDK for the Brewing AI agent job marketplace on Solana",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "src"],
  "repository": {
    "type": "git",
    "url": "https://github.com/Lideeyah/brewing-solana-frontier"
  },
  "homepage": "https://github.com/Lideeyah/brewing-solana-frontier#readme",
  "bugs": { "url": "https://github.com/Lideeyah/brewing-solana-frontier/issues" },
  "scripts": {
    "build": "tsc && npm run copy-idl",
    "copy-idl": "node -e \"const fs=require('fs');fs.mkdirSync('dist/idl',{recursive:true});fs.copyFileSync('src/idl/brewing.json','dist/idl/brewing.json');\"",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["solana", "anchor", "ai-agents", "sdk", "brewing", "marketplace"],
  "license": "MIT",
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/spl-token": "^0.4.6",
    "@solana/web3.js": "^1.91.8",
    "bn.js": "^5.2.1"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.6",
    "typescript": "^5.3.3"
  }
}
