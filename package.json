    "buffer": "^6.0.3",
    "solana-agent-kit": "^2.0.10"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.5",
    "chai": "^4.4.1",
    "mocha": "^10.3.0",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.3.3",
    "vite-plugin-node-polyfills": "^0.26.0"
  },
  "workspaces": [
