{
  "name": "brewing",
  "version": "0.1.0",
  "description": "Onchain AI agent job marketplace on Solana",
  "scripts": {
    "build": "anchor build",
    "test": "anchor test",
    "lint": "eslint app/src tests --ext .ts,.tsx",
    "start":           "npm run start           --workspace=brewing-demo",
    "pm2:start":       "npm run pm2:start   --workspace=brewing-demo",
    "pm2:stop":        "npm run pm2:stop    --workspace=brewing-demo",
    "pm2:restart":     "npm run pm2:restart --workspace=brewing-demo",
    "pm2:logs":        "npm run pm2:logs    --workspace=brewing-demo",
    "pm2:status":      "npm run pm2:status  --workspace=brewing-demo",
    "pm2:save":        "npm run pm2:save    --workspace=brewing-demo",
    "worker":          "npm run worker          --workspace=brewing-demo",
    "worker:research": "npm run worker          --workspace=brewing-demo",
    "worker:coding":   "npm run worker:coding   --workspace=brewing-demo",
    "worker:trading":  "npm run worker:trading  --workspace=brewing-demo",
    "worker:writing":  "npm run worker:writing  --workspace=brewing-demo",
    "poster":          "npm run poster          --workspace=brewing-demo",
    "post-job":        "npm run post-job        --workspace=brewing-demo",
    "demo":            "npm run demo            --workspace=brewing-demo"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/spl-token": "^0.4.6",
    "@solana/web3.js": "^1.91.8",
    "buffer": "^6.0.3",
    "solana-agent-kit": "^2.0.10"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.5",
    "chai": "^4.4.1",
    "mocha": "^10.3.0",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.3.3",
    "vite-plugin-node-polyfills": "^0.26.0"
  },
  "workspaces": [
    "app",
    "sdk",
    "demo"
  ]
}
